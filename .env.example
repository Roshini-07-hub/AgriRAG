# Gemini API Key (embeddings only) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (LLM responses) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Chroma Cloud - https://app.trychroma.com
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=your_database_name_here
CHROMA_COLLECTION=rag-collection

# LangSmith tracing - https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=rag-basic
